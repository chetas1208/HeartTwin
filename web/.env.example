# HeartTwin web (Next.js + CopilotKit) — environment
# Copy to .env.local and fill in. All .env* files are gitignored.

# Backend origin (HeartTwin FastAPI, served under /api/v1). The browser uses
# this for REST + the SSE trace stream, and the CopilotKit route derives the
# /copilotkit origin from it.
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1

# Server-only override for the CopilotKit route's backend origin.
# Optional — defaults to NEXT_PUBLIC_API_BASE when unset.
# API_BASE=http://localhost:8000/api/v1

# OpenAI — the reasoning brain that drives the CopilotKit chat and calls the
# HeartTwin backend actions (create_case / extract / operate / ...).
# Required: the route fails loud without a key (no silent fallback).
OPENAI_API_KEY=
# Chat model for the CopilotKit adapter (the route defaults to gpt-4o if unset).
OPENAI_MODEL=gpt-4o
