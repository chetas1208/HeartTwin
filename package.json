{
  "name": "hearttwin-lab",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vercel dev --listen ${PORT:-3001}",
    "dev:nuxt": "nuxt dev --port ${PORT:-3001}",
    "dev:split": "bash -lc 'set -e; API_PORT=\"${API_PORT:-8001}\"; FRONTEND_PORT=\"${PORT:-3001}\"; python -m uvicorn python.hearttwin.api:app --host 127.0.0.1 --port \"$API_PORT\" & api_pid=$!; cleanup(){ kill \"$api_pid\" 2>/dev/null || true; }; trap cleanup EXIT INT TERM; NUXT_PUBLIC_API_BASE=\"http://localhost:${API_PORT}/api/v1\" nuxt dev --port \"$FRONTEND_PORT\"'",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "test:py": "python -m pytest python/hearttwin/tests",
    "test:e2e": "playwright test tests/e2e",
    "test:api": "playwright test tests/api",
    "test:all": "pnpm test:py && pnpm test:api && pnpm test:e2e",
    "verify:env": "python scripts/verify_env.py",
    "verify:repo": "python scripts/verify_repo_structure.py",
    "verify:vercel": "python scripts/verify_vercel_readiness.py",
    "verify:all": "pnpm verify:env && pnpm verify:repo && pnpm verify:vercel && pnpm check && pnpm build && pnpm test:py && pnpm test:api",
    "fixtures:gen": "python scripts/create_synthetic_fixtures.py",
    "smoke:local": "python scripts/run_local_smoke.py",
    "smoke:prod": "playwright test tests/e2e/07-production-smoke.spec.ts",
    "check": "pnpm typecheck && pnpm lint && pnpm test:py"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.11.3",
    "@tresjs/core": "^5.8.1",
    "@tresjs/nuxt": "^5.6.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "nuxt": "^4.4.7",
    "pinia": "^3.0.4",
    "plotly.js-dist-min": "^2.35.2",
    "three": "^0.170.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@playwright/test": "^1.49.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/node": "^22.0.0",
    "@types/three": "^0.170.0",
    "autoprefixer": "^10.4.20",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vercel": "^54.9.1"
  }
}
